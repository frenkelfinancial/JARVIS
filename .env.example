# ════════════════════════════════════════════════════════
#   JARVIS — Environment Variables
#   Copy this file to .env and fill in your values.
#   Never commit .env to git.
# ════════════════════════════════════════════════════════

# ── Core AI ──────────────────────────────────────────────
# Required by: Commission Agent, Etsy Agent, Video Script Agent, Jarvis AI
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── SMS via Telnyx ───────────────────────────────────────
# Required by: main.py (daily brief delivery) and SMS webhook
# Get these at: https://portal.telnyx.com
TELNYX_API_KEY=KEY_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELNYX_NUMBER=+1XXXXXXXXXX
YOUR_NUMBER=+1XXXXXXXXXX

# ── Voice Synthesis via ElevenLabs ───────────────────────
# Required by: Video Script Agent
# Get these at: https://elevenlabs.io
ELEVENLABS_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Etsy Listing Agent ───────────────────────────────────
# Optional — auto-draft listings via Etsy API v3
# Get OAuth token + shop ID at: https://www.etsy.com/developers/your-account
ETSY_API_KEY=your_etsy_oauth_access_token
ETSY_SHOP_ID=12345678
ETSY_SHIPPING_PROFILE_ID=12345678

# ── Commission Agent (Gmail OAuth) ───────────────────────
# Required by: Commission Agent
# Create OAuth credentials at: console.cloud.google.com
# Download as credentials.json and place in the Jarvis root folder
# (First run opens a browser to authorize Gmail read access)

# ── Lead Monitor Agent ───────────────────────────────────
# Option A: HubSpot
HUBSPOT_API_KEY=pat-na1-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Option B: GoHighLevel
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_location_id

# ── Video Pipeline Agent ─────────────────────────────────
# Required by: Video Pipeline Agent
YOUTUBE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Income Goals ─────────────────────────────────────────
# Optional — set your production targets
MONTHLY_PREMIUM_GOAL=20000
MONTHLY_COMMISSION_GOAL=8000
ANNUAL_PREMIUM_GOAL=240000

# ── Scheduler ────────────────────────────────────────────
# Overrides the default 08:00 daily brief time (24h format)
DAILY_BRIEF_TIME=08:00
